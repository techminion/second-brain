# Public Supabase connection values. These are intentionally exposed to the browser.
# Vercel Preview targets the shared development project; Production targets its own project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secrets. Never prefix a secret with NEXT_PUBLIC_.
# Preview and Production values are distinct; never copy the production key into tests.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
EMBEDDING_WEBHOOK_SECRET=
PURGE_WEBHOOK_SECRET=
